<?php
require_once __DIR__ . '/backend/bootstrap.php';
$product = get_product_by_id((int)($_GET['id'] ?? 0));
if (!$product || empty($product['id_auction'])) { http_response_code(404); exit('Enchère introuvable.'); }
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    require_login();
    verify_csrf();
    $result = place_bid((int)$product['id_auction'], current_user_id(), (float)str_replace(',', '.', $_POST['montant'] ?? 0));
    flash($result['success'] ? 'success' : 'error', $result['message']);
    redirect('enchere.php?id=' . (int)$product['id_product']);
}
$history = get_bid_history((int)$product['id_auction']);
$pageTitle = 'Enchère - ' . $product['titre'];
require_once __DIR__ . '/partials/header.php';
?>
<section class="auction-layout">
    <div class="detail-media"><img class="detail-image" src="<?= e(url($product['image'] ?: DEFAULT_PRODUCT_IMAGE)) ?>" alt="<?= e($product['titre']) ?>"></div>
    <div class="detail-info">
        <p class="eyebrow">Vente par enchère</p><h1><?= e($product['titre']) ?></h1><p class="muted"><?= e($product['description']) ?></p>
        <div class="dashboard-grid" style="grid-template-columns:repeat(2,1fr)"><div class="dashboard-card"><strong><?= money_format_fr((float)$product['prix_actuel']) ?></strong><span>Prix actuel</span></div><div class="dashboard-card"><strong><?= count($history) ?></strong><span>Offres</span></div></div>
        <p>Date de fin : <strong><?= e($product['date_fin']) ?></strong></p><div id="auction-timer" data-end="<?= e($product['date_fin']) ?>"></div>
