require_once __DIR__ . '/backend/bootstrap.php';
if (is_logged_in()) { redirect('espace-client.php'); }
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    verify_csrf();
    if (login_user($_POST['email'] ?? '', $_POST['password'] ?? '')) {
        flash('success', 'Connexion réussie.');
        redirect(has_role('admin') ? 'espace-admin.php' : (has_role('vendeur') ? 'espace-vendeur.php' : 'espace-client.php'));
    }
    flash('error', 'Email ou mot de passe incorrect.');
}
$pageTitle = 'Connexion - Mercato Nova';
require_once __DIR__ . '/partials/header.php';
