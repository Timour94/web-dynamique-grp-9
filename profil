<?php
require_once __DIR__ . '/backend/bootstrap.php';
require_login();

$user = current_user();
if (!$user) {
    redirect('connexion.php');
}

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    verify_csrf();
    $result = update_user_profile((int)$user['id_user'], $_POST);
    if ($result['success']) {
        flash('success', 'Profil mis à jour avec succès.');
        redirect('profil.php');
    }
    foreach ($result['errors'] as $error) {
        flash('error', $error);
    }
    $user = array_merge($user, [
        'prenom' => $_POST['prenom'] ?? $user['prenom'],
        'nom' => $_POST['nom'] ?? $user['nom'],
        'telephone' => $_POST['telephone'] ?? $user['telephone'],
        'adresse' => $_POST['adresse'] ?? $user['adresse'],
        'ville' => $_POST['ville'] ?? $user['ville'],
        'code_postal' => $_POST['code_postal'] ?? $user['code_postal'],
    ]);
}

$pageTitle = 'Mon profil - Mercato Nova';
