<?php
require_once __DIR__ . '/backend/bootstrap.php';
require_role(['vendeur','admin']);
$product = get_product_by_id((int)($_GET['id'] ?? 0));
if (!$product || !can_manage_product($product)) { http_response_code(403); exit('Accès refusé.'); }
$categories = get_categories();
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    verify_csrf();
    $image = handle_product_image_upload('image');
    $result = update_product((int)$product['id_product'], $_POST, current_user_id(), $image);
    if ($result['success']) { flash('success', 'Annonce modifiée.'); redirect('espace-vendeur.php'); }
    foreach ($result['errors'] as $error) { flash('error', $error); }
}
$pageTitle = 'Modifier annonce - Mercato Nova';
require_once __DIR__ . '/partials/header.php';
?>
<section class="auth-card wide">
<h1>Modifier l’annonce</h1>
<form method="post" enctype="multipart/form-data" class="form-grid">
<?= csrf_field() ?>
<input name="titre" value="<?= e($product['titre']) ?>" required>
<select name="id_categorie" required><?php foreach ($categories as $cat): ?><option value="<?= (int)$cat['id_categorie'] ?>" <?= (int)$product['id_categorie']===(int)$cat['id_categorie']?'selected':'' ?>><?= e($cat['nom_categorie']) ?></option><?php endforeach; ?></select>
<input name="etat_produit" value="<?= e($product['etat_produit']) ?>">
<input type="number" name="stock" min="1" value="<?= (int)$product['stock'] ?>">
<input type="number" step="0.01" name="prix_achat_immediat" value="<?= e((string)$product['prix_achat_immediat']) ?>">
<input type="file" name="image" accept="image/*">
<textarea name="description" required><?= e($product['description']) ?></textarea>
<button class="btn full" type="submit">Enregistrer</button>
</form>
</section>
<?php require_once __DIR__ . '/partials/footer.php'; ?>
