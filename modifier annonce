<?php
require_once __DIR__ . '/backend/bootstrap.php';
require_role(['vendeur','admin']);

$product = get_product_by_id((int)($_GET['id'] ?? 0));
if (!$product || !can_manage_product($product)) {
    http_response_code(403);
    exit('Accès refusé.');
}
if ($product['statut'] === 'vendu') {
    flash('error', 'Impossible de modifier une annonce déjà vendue.');
    redirect('espace-vendeur.php');
}

$categories = get_categories();
$images = get_product_images((int)$product['id_product']);

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    verify_csrf();
    $uploadedImages = collect_product_uploaded_images();
    $result = update_product((int)$product['id_product'], $_POST, current_user_id(), $uploadedImages);
    if ($result['success']) {
        flash('success', 'Annonce modifiée. Galerie et paramètres mis à jour.');
        redirect('modifier-annonce.php?id=' . (int)$product['id_product']);
    }
    foreach ($result['errors'] as $error) {
        flash('error', $error);
    }
    $product = get_product_by_id((int)$product['id_product']) ?: array_merge($product, $_POST);
    $images = get_product_images((int)$product['id_product']);
}

$pageTitle = 'Modifier annonce - Mercato Nova';
require_once __DIR__ . '/partials/header.php';
