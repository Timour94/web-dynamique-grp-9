require_once __DIR__ . '/backend/bootstrap.php';
require_role('admin');

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    verify_csrf();

    if (isset($_POST['moderate'])) {
        $ok = moderate_product((int)($_POST['id_product'] ?? 0), (string)$_POST['moderate'], current_user_id());
        flash($ok ? 'success' : 'error', $ok ? 'Action de modération enregistrée.' : 'Action de modération impossible.');
        redirect('espace-admin.php');
    }

    if (isset($_POST['user_status'])) {
        $ok = set_user_status((int)($_POST['id_user'] ?? 0), (string)$_POST['user_status'], current_user_id());
        flash($ok ? 'success' : 'error', $ok ? 'Statut utilisateur modifié.' : 'Statut utilisateur invalide.');
        redirect('espace-admin.php');
    }

    if (isset($_POST['report_status'])) {
        $ok = update_report_status((int)($_POST['id_report'] ?? 0), (string)$_POST['report_status'], current_user_id());
        flash($ok ? 'success' : 'error', $ok ? 'Signalement mis à jour.' : 'Impossible de mettre à jour ce signalement.');
        redirect('espace-admin.php');
    }
}

